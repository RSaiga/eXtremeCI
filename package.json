    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^30.0.0",
    "lint-staged": "^15.2.11",
    "prettier": "^3.4.2",
    "react-chartjs-2": "^5.3.1",
